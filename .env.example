# Google Fact Check Tools API (gratis)
# Obtener en: https://console.cloud.google.com/apis/credentials
FACT_CHECK_API_KEY=

# Telegram Bot (gratis)
# Obtener token via @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
# Channel ID - enviar mensaje al canal y usar @userinfobot para obtener el ID
TELEGRAM_CHANNEL_ID=

# Configuración
MIN_SOURCES=3
RUN_INTERVAL_MIN=15
